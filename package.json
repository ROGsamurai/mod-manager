{
  "name": "tcg-card-shop-mod-manager",
  "version": "1.0.6",
  "description": "Real TCG Overhaul Mod Manager",
  "author": {
    "name": "iiTzSamurai",
    "url": "https://discord.gg/NHSvm22TSh"
  },
  "license": "UNLICENSED",
  "homepage": "https://discord.gg/NHSvm22TSh",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --win",
    "start": "electron ."
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0",
    "node-7z": "^3.0.0",
    "node-stream-zip": "^1.15.0",
    "7zip-bin": "^5.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "29.4.6",
    "electron-builder": "24.13.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vite": "5.4.14",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.iitzsamurai.tcgmodmanager",
    "productName": "Real TCG Overhaul Mod Manager",
    "copyright": "Copyright © 2026 iiTzSamurai. All Rights Reserved.",
    "directories": {
      "output": "build"
    },
    "compression": "normal",
    "removePackageScripts": true,
    "asar": true,
    "asarUnpack": [
      "**/node_modules/7zip-bin/**/*",
      "**/node_modules/node-7z/**/*"
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "dist/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "Real-TCG-Overhaul-Mod-Manager-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": true,
      "publisherName": "iiTzSamurai"
    },
    "portable": {
      "artifactName": "Real TCG Overhaul Mod Manager.exe",
      "requestExecutionLevel": "user",
      "unpackDirName": "Real-TCG-Overhaul-Mod-Manager"
    },
    "extraMetadata": {
      "name": "TCG Card Shop Mod Manager",
      "description": "Real TCG Overhaul Mod Manager",
      "author": "iiTzSamurai"
    }
  }
}
